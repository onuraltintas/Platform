{
  "ConnectionStrings": {
    "DefaultConnection": "${CONNECTIONSTRINGS__DEFAULTCONNECTION}",
    "Redis": "${CONNECTIONSTRINGS__REDIS}"
  },
  "Jwt": {
    "SecretKey": "${JWT__SECRETKEY}",
    "Issuer": "${JWT__ISSUER}",
    "Audience": "${JWT__AUDIENCE}",
    "ExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 7,
    "Algorithm": "HS256"
  },
  "GoogleAuth": {
    "ClientId": "${GOOGLEAUTH__CLIENTID}",
    "ClientSecret": "${GOOGLEAUTH__CLIENTSECRET}",
    "RedirectUri": "${GOOGLEAUTH__REDIRECTURI}"
  },
  "Logging": {
    "MinimumLevel": "Information",
    "Console": {
      "Enabled": true,
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/identity-service-.log",
      "RollingInterval": "Day",
      "FileSizeLimitBytes": 104857600,
      "RetainedFileCountLimit": 31,
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    }
  },
  "Features": {
    "EnableGoogleAuth": true,
    "EnableRememberMe": true,
    "EnableEmailConfirmation": true,
    "RequireStrongPasswords": true,
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30
  }
}