{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "EgitimPlatform.IdentityService",
    "Audience": "EgitimPlatform.Users",
    "ExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 7,
    "Algorithm": "HS256"
  },
  "Google": {
    "ClientId": "${GOOGLE_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
    "RedirectUri": "${GOOGLE_REDIRECT_URI}",
    "AuthorizationEndpoint": "${GOOGLE_AUTHORIZATION_ENDPOINT}",
    "TokenEndpoint": "${GOOGLE_TOKEN_ENDPOINT}",
    "UserInfoEndpoint": "${GOOGLE_USER_INFO_ENDPOINT}",
    "Scope": "${GOOGLE_SCOPE}"
  },
  "Logging": {
    "MinimumLevel": "Information",
    "Console": {
      "Enabled": true,
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/identity-service-.log",
      "RollingInterval": "Day",
      "FileSizeLimitBytes": 104857600,
      "RetainedFileCountLimit": 31,
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "Enrichment": {
      "WithMachineName": true,
      "WithEnvironmentUserName": true,
      "WithProcessId": true,
      "WithProcessName": true,
      "WithThreadId": true,
      "WithThreadName": true
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "EnableGoogleAuth": true,
    "EnableRememberMe": true,
    "EnableEmailConfirmation": true,
    "RequireStrongPasswords": true,
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30
  },
  "Email": {
    "Smtp": {
      "Host": "localhost",
      "Port": 587,
      "Username": "",
      "Password": "",
      "EnableSsl": false,
      "EnableStartTls": true,
      "TimeoutSeconds": 30,
      "UseDefaultCredentials": false
    },
    "Settings": {
      "DefaultFromEmail": "noreply@example.com",
      "DefaultFromName": "EğitimPlatform",
      "DefaultReplyToEmail": "noreply@example.com",
      "DefaultReplyToName": "EğitimPlatform Destek",
      "DefaultSubjectPrefix": "",
      "DefaultEncoding": "UTF-8",
      "DefaultPriority": "Normal",
      "TrackOpens": false,
      "TrackClicks": false,
      "EnableUnsubscribe": false
    },
    "Templates": {
      "Enabled": false,
      "TemplatesPath": "EmailTemplates",
      "Engine": "None",
      "CacheTemplates": false,
      "CacheExpirationMinutes": 60
    },
    "Security": {
      "RequireTls": false,
      "ValidateCertificates": true,
      "LogSensitiveData": false,
      "RequireSSL": false,
      "MaxAttachmentSizeMB": 10
    },
    "Throttling": {
      "Enabled": false,
      "MaxEmailsPerMinute": 100,
      "MaxEmailsPerHour": 1000,
      "MaxEmailsPerDay": 10000,
      "DelayBetweenEmailsMs": 0,
      "BulkEmailBatchSize": 10
    },
    "Queue": {
      "Enabled": false,
      "ProcessingIntervalSeconds": 10,
      "MaxBatchSize": 10,
      "DeliveryResultRetentionDays": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMinutes": 5
    },
    "Validation": {
      "Enabled": true,
      "ValidateEmailFormat": true,
      "ValidationLevel": "Basic"
    }
  }
}