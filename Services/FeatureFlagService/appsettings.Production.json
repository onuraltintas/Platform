{
  "ConnectionStrings": {
    "DefaultConnection": "${CONNECTIONSTRINGS__DEFAULTCONNECTION}",
    "Redis": "${CONNECTIONSTRINGS__REDIS}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "${JWT__SECRETKEY}",
    "Issuer": "EgitimPlatform.FeatureFlagService",
    "Audience": "EgitimPlatform.Services",
    "ExpirationInMinutes": 60
  },
  "ApiGateway": {
    "BaseUrl": "${APIGATEWAY__BASEURL}"
  },
  "FeatureFlags": {
    "Cache": {
      "ExpirationMinutes": 5,
      "MaxEntries": 1000
    },
    "Evaluation": {
      "DefaultTimeout": 5000,
      "MaxBatchSize": 50
    },
    "Analytics": {
      "BatchSize": 100,
      "FlushIntervalSeconds": 30
    }
  },
  "ABTesting": {
    "DefaultSignificanceLevel": 0.05,
    "DefaultMinSampleSize": 100,
    "DefaultMaxDurationDays": 30,
    "StatisticalEngine": "TTest"
  },
  "RabbitMQ": {
    "Host": "${RABBITMQ__HOST}",
    "Port": 5672,
    "Username": "${RABBITMQ__USERNAME}",
    "Password": "${RABBITMQ__PASSWORD}",
    "VirtualHost": "/",
    "Queues": {
      "FeatureFlagEvents": "feature-flag-events",
      "ABTestEvents": "ab-test-events"
    }
  }
}