# =============================================================================
# EgitimPlatform Environment Configuration
# =============================================================================
# Bu dosya, EgitimPlatform projesinin environment konfigürasyonunu içerir.
# Kullanım: cp env.example .env
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
DB_SERVER=sqlserver
DB_PORT=1433
DB_NAME_IDENTITY=EgitimPlatform_Identity
DB_NAME_USER_SERVICE=EgitimPlatform_UserService
DB_NAME_NOTIFICATION_SERVICE=EgitimPlatform_NotificationService
DB_NAME_FEATURE_FLAG_SERVICE=EgitimPlatform_FeatureFlagService
DB_USER=EgitimPlatformUser
DB_PASSWORD=EgitimPlatform123!
DB_TRUST_SERVER_CERTIFICATE=true

# Açıklama:
# - DB_USER uygulamaların bağlanacağı kullanıcıdır (EgitimPlatformUser).
# - DB_PASSWORD hem SA hem de EgitimPlatformUser için başlangıç parolası olarak kullanılır
#   (docker/database/init.sql giriş scripti EgitimPlatformUser login’ini aynı parola ile yaratır).
#   Production’da SA parolasını farklı ve daha güçlü tanımlamanız önerilir.

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET_KEY=EgitimPlatformSuperSecretKey2024!
JWT_ISSUER=EgitimPlatform
JWT_AUDIENCE=EgitimPlatform
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_EMAIL=noreply@egitimplatform.com
EMAIL_FROM_NAME=Eğitim Platform

# =============================================================================
# Google OAuth Configuration
# =============================================================================
# Google Cloud Console'dan alınan OAuth 2.0 bilgileri
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5002/api/auth/google/callback
GOOGLE_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_ENDPOINT=https://www.googleapis.com/oauth2/v2/userinfo
GOOGLE_SCOPE=openid email profile

# =============================================================================
# Service Ports Configuration
# =============================================================================
# API Gateway
API_GATEWAY_PORT=5000
API_GATEWAY_HTTPS_PORT=5001

# Identity Service
IDENTITY_SERVICE_PORT=5002
IDENTITY_SERVICE_HTTPS_PORT=5003

# User Service
USER_SERVICE_PORT=5004
USER_SERVICE_HTTPS_PORT=5005

# Notification Service
NOTIFICATION_SERVICE_PORT=5006
NOTIFICATION_SERVICE_HTTPS_PORT=5007

# Feature Flag Service
FEATURE_FLAG_SERVICE_PORT=5008
FEATURE_FLAG_SERVICE_HTTPS_PORT=5009

# =============================================================================
# Environment Configuration
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=Information
LOG_RETENTION_DAYS=30

# =============================================================================
# Security Configuration
# =============================================================================
# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# =============================================================================
# Feature Flags Configuration
# =============================================================================
FEATURE_FLAGS_ENABLED=true
FEATURE_FLAGS_CACHE_DURATION_MINUTES=5

# =============================================================================
# Monitoring and Observability
# =============================================================================
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_HEALTH_CHECKS=true

# =============================================================================
# Messaging (RabbitMQ)
# =============================================================================
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# =============================================================================
# Development Specific Settings
# =============================================================================
# Debug settings (sadece development ortamında kullanın)
DEBUG_MODE=false
ENABLE_DETAILED_ERRORS=false
ENABLE_SENSITIVE_DATA_LOGGING=false

# =============================================================================
# Production Override Examples
# =============================================================================
# Production ortamında aşağıdaki değerleri güncelleyin:
# ASPNETCORE_ENVIRONMENT=Production
# DB_PASSWORD=YourStrongProductionPassword123!@#
# JWT_SECRET_KEY=YourVeryLongSecretKeyAtLeast256BitsLongForSecurity
# GOOGLE_CLIENT_ID=your-production-google-client-id
# GOOGLE_CLIENT_SECRET=your-production-google-client-secret
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# LOG_LEVEL=Warning
# DEBUG_MODE=false 