{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "https://localhost:7258/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": {
            "Address": "https://localhost:5005/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "https://localhost:7086/"
          }
        }
      },
      "feature-flag-cluster": {
        "Destinations": {
          "feature-flag-service": {
            "Address": "https://localhost:7004/"
          }
        }
      },
      "sr-content-cluster": {
        "Destinations": {
          "sr-content-service": { "Address": "http://localhost:5201/" }
        }
      },
      "sr-profile-cluster": {
        "Destinations": {
          "sr-profile-service": { "Address": "http://localhost:5202/" }
        }
      },
      "sr-progress-cluster": {
        "Destinations": {
          "sr-progress-service": { "Address": "http://localhost:5203/" }
        }
      }
    },
    "Routes": {
      "sr-content": { "ClusterId": "sr-content-cluster", "Match": { "Path": "/sr-content/{**catch-all}" } },
      "sr-profile": { "ClusterId": "sr-profile-cluster", "Match": { "Path": "/sr-profile/{**catch-all}" } },
      "sr-progress": { "ClusterId": "sr-progress-cluster", "Match": { "Path": "/sr-progress/{**catch-all}" } }
    }
  },
  "HealthChecks": {
    "UI": {
      "HealthCheckEndpoints": [
        { "Name": "API Gateway", "Uri": "http://localhost:5000/health" },
        { "Name": "Identity Service", "Uri": "https://localhost:7258/health" },
        { "Name": "User Service", "Uri": "https://localhost:5005/health" },
        { "Name": "Notification Service", "Uri": "https://localhost:7086/health" },
        { "Name": "Feature Flag Service", "Uri": "https://localhost:7004/health" },
        { "Name": "SR Content Service", "Uri": "http://localhost:5201/health" },
        { "Name": "SR Profile Service", "Uri": "http://localhost:5202/health" },
        { "Name": "SR Progress Service", "Uri": "http://localhost:5203/health" }
      ],
      "EvaluationTimeInSeconds": 10,
      "MinimumSecondsBetweenFailureNotifications": 60
    }
  }
}
