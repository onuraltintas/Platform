{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "EgitimPlatform.IdentityService",
    "Audience": "EgitimPlatform.Users",
    "ExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 7,
    "Algorithm": "HS256"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "identity-admin-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/admin/{**catch-all}"
          }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "user-profiles-v1-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/v1/profiles/{**catch-all}" },
        "Transforms": [
          {
            "PathPattern": "/api/v1/profiles/{**catch-all}"
          }
        ]
      },
      "user-settings-v1-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/v1/settings/{**catch-all}" },
        "Transforms": [
          {
            "PathPattern": "/api/v1/settings/{**catch-all}"
          }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "feature-flag-route": {
        "ClusterId": "feature-flag-cluster",
        "Match": {
          "Path": "/api/v1/features/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v1-sr-content-route": {
        "ClusterId": "sr-content-cluster",
        "Match": { "Path": "/api/sr-content/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/{**catch-all}" } ]
      },
      "v1-sr-profile-route": {
        "ClusterId": "sr-profile-cluster",
        "Match": { "Path": "/api/sr-profile/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/{**catch-all}" } ]
      },
      "v1-sr-progress-route": {
        "ClusterId": "sr-progress-cluster",
        "Match": { "Path": "/api/sr-progress/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/{**catch-all}" } ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://identity-service/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": {
            "Address": "http://user-service/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://notification-service/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "feature-flag-cluster": {
        "Destinations": {
          "feature-flag-service": {
            "Address": "http://featureflag-service/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "sr-content-cluster": {
        "Destinations": {
          "sr-content-service": { "Address": "http://sr-content-service/" }
        }
      },
      "sr-profile-cluster": {
        "Destinations": {
          "sr-profile-service": { "Address": "http://sr-profile-service/" }
        }
      },
      "sr-progress-cluster": {
        "Destinations": {
          "sr-progress-service": { "Address": "http://sr-progress-service/" }
        }
      }
    }
  },
  "RateLimiting": {
    "GlobalPolicy": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "ReplenishmentPeriod": "00:00:10",
      "QueueLimit": 0,
      "QueueProcessingOrder": "OldestFirst"
    },
    "AuthenticatedPolicy": {
      "PermitLimit": 200,
      "Window": "00:01:00",
      "ReplenishmentPeriod": "00:00:10",
      "QueueLimit": 10,
      "QueueProcessingOrder": "OldestFirst"
    },
    "AdminPolicy": {
      "PermitLimit": 500,
      "Window": "00:01:00",
      "ReplenishmentPeriod": "00:00:05",
      "QueueLimit": 20,
      "QueueProcessingOrder": "OldestFirst"
    }
  },
  "Logging": {
    "MinimumLevel": "Information",
    "Console": {
      "Enabled": true,
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/gateway-.log",
      "RollingInterval": "Day",
      "FileSizeLimitBytes": 104857600,
      "RetainedFileCountLimit": 31,
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "Enrichment": {
      "WithMachineName": true,
      "WithEnvironmentUserName": true,
      "WithProcessId": true,
      "WithProcessName": true,
      "WithThreadId": true,
      "WithThreadName": true
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Certificates": {
      "Default": {
        "Path": "",
        "Password": ""
      }
    }
  },
  "Https": {
    "Port": 7001,
    "Protocols": "Http1AndHttp2"
  },
  "ApiVersioning": {
    "DefaultVersion": "v1",
    "SupportedVersions": ["v1", "v2", "v3"],
    "VersionMappings": {
      "v1": "v1",
      "v2": "v2",
      "v3": "v3"
    },
    "Routes": {
      "v1-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "v1-admin-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/admin/{**catch-all}"
          }
        ]
      },
      "v1-users-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v1-profiles-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/v1/profiles/{**catch-all}" },
        "Transforms": [
          {
            "PathPattern": "/api/v1/profiles/{**catch-all}"
          }
        ]
      },
      "v1-settings-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/v1/settings/{**catch-all}" },
        "Transforms": [
          {
            "PathPattern": "/api/v1/settings/{**catch-all}"
          }
        ]
      },
      "v1-notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v1-features-route": {
        "ClusterId": "feature-flag-cluster",
        "Match": {
          "Path": "/api/v1/features/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v2-identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v2/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v2-users-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v2/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "v2-notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v2/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      }
    }
  },
  "HealthChecks": {
    "UI": {
      "HealthCheckDatabaseName": "HealthCheckDb",
      "EvaluationTimeInSeconds": 10,
      "MinimumSecondsBetweenFailureNotifications": 60
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:3000",
      "https://localhost:3000",
      "https://admin.localhost:4200",
      "https://api.localhost:7001",
      "https://gateway.localhost:7001"
    ]
  }
}
