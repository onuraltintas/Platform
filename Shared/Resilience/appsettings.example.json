{
  "Resilience": {
    "Retry": {
      "Enabled": true,
      "MaxRetryAttempts": 3,
      "BaseDelaySeconds": 1.0,
      "MaxDelaySeconds": 30.0,
      "BackoffType": "ExponentialWithJitter",
      "JitterFactor": 0.1,
      "RetryableExceptions": [
        "System.Net.Http.HttpRequestException",
        "System.TimeoutException",
        "System.Net.Sockets.SocketException",
        "System.Threading.Tasks.TaskCanceledException"
      ],
      "RetryableHttpStatusCodes": [500, 502, 503, 504, 408, 429]
    },
    
    "CircuitBreaker": {
      "Enabled": true,
      "FailureThreshold": 5,
      "FailureRatio": 0.5,
      "MinimumThroughput": 10,
      "SamplingDurationSeconds": 30.0,
      "BreakDurationSeconds": 60.0,
      "HandledExceptions": [
        "System.Net.Http.HttpRequestException",
        "System.TimeoutException",
        "System.Net.Sockets.SocketException"
      ],
      "HandledHttpStatusCodes": [500, 502, 503, 504]
    },
    
    "Timeout": {
      "Enabled": true,
      "TimeoutSeconds": 30.0,
      "Strategy": "Pessimistic"
    },
    
    "Bulkhead": {
      "Enabled": false,
      "MaxParallelization": 10,
      "MaxQueuedActions": 100
    },
    
    "RateLimiter": {
      "Enabled": false,
      "Type": "TokenBucket",
      "PermitLimit": 100,
      "WindowSeconds": 60.0,
      "QueueLimit": 0,
      "AutoReplenishment": true,
      "ReplenishmentPeriodSeconds": 1.0,
      "TokensPerPeriod": 10
    },
    
    "Fallback": {
      "Enabled": false,
      "Action": "ReturnDefault",
      "FallbackValue": null,
      "HandledExceptions": [
        "System.Net.Http.HttpRequestException",
        "System.TimeoutException",
        "Polly.CircuitBreaker.CircuitBreakerOpenException"
      ]
    },
    
    "Hedging": {
      "Enabled": false,
      "MaxHedgedAttempts": 2,
      "DelaySeconds": 1.0,
      "HandledExceptions": [
        "System.TimeoutException",
        "System.Threading.Tasks.TaskCanceledException"
      ]
    },
    
    "Services": {
      "UserService": {
        "ServiceName": "UserService",
        "Retry": {
          "Enabled": true,
          "MaxRetryAttempts": 2,
          "BaseDelaySeconds": 0.5,
          "BackoffType": "Linear"
        },
        "Timeout": {
          "Enabled": true,
          "TimeoutSeconds": 15.0
        }
      },
      
      "NotificationService": {
        "ServiceName": "NotificationService",
        "Retry": {
          "Enabled": true,
          "MaxRetryAttempts": 5,
          "BaseDelaySeconds": 1.0,
          "BackoffType": "Exponential"
        },
        "CircuitBreaker": {
          "Enabled": true,
          "FailureThreshold": 3,
          "BreakDurationSeconds": 30.0
        }
      },
      
      "ExternalApi": {
        "ServiceName": "ExternalApi",
        "Retry": {
          "Enabled": true,
          "MaxRetryAttempts": 3,
          "BaseDelaySeconds": 2.0,
          "BackoffType": "ExponentialWithJitter"
        },
        "CircuitBreaker": {
          "Enabled": true,
          "FailureThreshold": 5,
          "BreakDurationSeconds": 120.0
        },
        "Timeout": {
          "Enabled": true,
          "TimeoutSeconds": 60.0
        },
        "Fallback": {
          "Enabled": true,
          "Action": "ReturnCached"
        }
      }
    }
  }
}