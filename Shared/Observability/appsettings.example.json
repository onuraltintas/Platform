{
  "Observability": {
    "ServiceName": "EgitimPlatform.Service",
    "ServiceVersion": "1.0.0",
    "Environment": "Development",
    "ServiceInstanceId": "instance-001",
    
    "Tracing": {
      "Enabled": true,
      "SamplingRatio": 1.0,
      "TraceConsoleExporter": false,
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "RecordException": true,
      "SetErrorStatusOnException": true,
      
      "AspNetCore": {
        "Enabled": true,
        "RecordException": true,
        "EnableGrpcAspNetCoreSupport": false,
        "IgnorePatterns": ["/health", "/metrics", "/favicon.ico"]
      },
      
      "Http": {
        "Enabled": true,
        "RecordException": true,
        "IgnorePatterns": []
      },
      
      "Sql": {
        "Enabled": true,
        "SetDbStatementForText": false,
        "SetDbStatementForStoredProcedure": true,
        "RecordException": true,
        "EnableConnectionLevelAttributes": true
      },
      
      "EntityFramework": {
        "Enabled": true,
        "SetDbStatementForText": false,
        "SetDbStatementForStoredProcedure": true
      },
      
      "MassTransit": {
        "Enabled": true,
        "CaptureMessageHeaders": true,
        "CaptureMessagePayload": false
      }
    },
    
    "Metrics": {
      "Enabled": true,
      "PrometheusEnabled": true,
      "PrometheusEndpoint": "/metrics",
      "PrometheusPort": 9090,
      "ConsoleExporter": false,
      "ExportIntervalMilliseconds": 30000,
      "IncludeDefaultMetrics": true,
      "IncludeCustomMetrics": true
    },
    
    "Logging": {
      "IncludeTraceId": true,
      "IncludeSpanId": true,
      "IncludeActivity": true,
      "EnableStructuredLogging": true
    },
    
    "Exporters": {
      "Jaeger": {
        "Enabled": false,
        "Endpoint": "http://localhost:14268/api/traces",
        "Protocol": "UdpCompactThrift"
      },
      
      "Zipkin": {
        "Enabled": false,
        "Endpoint": "http://localhost:9411/api/v2/spans"
      },
      
      "Otlp": {
        "Enabled": false,
        "Endpoint": "http://localhost:4317",
        "Protocol": "Grpc",
        "Headers": {}
      }
    }
  }
}