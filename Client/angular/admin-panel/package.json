{
  "name": "admin-panel",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "analyze:exports": "ts-prune -p tsconfig.app.json",
    "analyze:deps": "depcheck --skip-missing=true",
    "analyze": "npm run analyze:exports && npm run analyze:deps"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.1.6",
    "@angular/build": "^20.1.4",
    "@angular/common": "20.1.6",
    "@angular/compiler": "20.1.6",
    "@angular/core": "20.1.6",
    "@angular/forms": "20.1.6",
    "@angular/platform-browser": "20.1.6",
    "@angular/router": "20.1.6",
    "@coreui/coreui": "^4.2.0",
    "@coreui/icons": "^3.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.11.3",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "ngx-toastr": "^18.0.0",
    "pdfmake": "^0.2.20",
    "rxjs": "~7.8.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/cli": "^20.1.4",
    "@angular/compiler-cli": "20.1.6",
    "@types/jasmine": "~5.1.0",
    "@types/pdfmake": "^0.2.11",
    "depcheck": "^1.4.3",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ts-prune": "^0.10.3",
    "typescript": "~5.8.2"
  }
}
